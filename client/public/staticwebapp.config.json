{
  "routes": [
    {
      "route": "/privacy",
      "rewrite": "/privacy/index.html"
    },
    {
      "route": "/privacy/",
      "rewrite": "/privacy/index.html"
    }
  ],
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/assets/*", "/manus-storage/*", "/__manus__/*", "/privacy/*"]
  }
}
